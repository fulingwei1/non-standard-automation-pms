#!/bin/bash

# Commit message validation hook
# Enforces conventional commit message format
# Bypasses validation for merge, revert, fixup, and squash commits

commit_msg_file="$1"
# 只读取第一行用于验证（多行消息只校验 subject line）
first_line="$(head -n 1 "$commit_msg_file")"

# --- 跳过不需要验证的特殊提交 ---
# Merge commits (git merge 自动生成)
if echo "$first_line" | grep -qE "^Merge "; then
    exit 0
fi
# Revert commits (git revert 自动生成)
if echo "$first_line" | grep -qE "^Revert "; then
    exit 0
fi
# fixup!/squash! commits (git commit --fixup/--squash 生成，rebase 时合并)
if echo "$first_line" | grep -qE "^(fixup|squash)! "; then
    exit 0
fi

# Define allowed commit types based on project git-workflow.md
allowed_types="feat|fix|refactor|docs|test|chore|perf|ci"

# Conventional commit pattern: <type>: <description>
# Optional scope: <type>(scope): <description>
pattern="^($allowed_types)(\(.+\))?: .{1,}"

# Check if first line matches pattern
if ! echo "$first_line" | grep -qE "$pattern"; then
    echo "Commit message validation failed!"
    echo ""
    echo "Your commit message:"
    echo "  $first_line"
    echo ""
    echo "Expected format:"
    echo "  <type>: <description>"
    echo "  or"
    echo "  <type>(scope): <description>"
    echo ""
    echo "Allowed types: feat, fix, refactor, docs, test, chore, perf, ci"
    echo ""
    echo "Examples:"
    echo "  feat: add user authentication"
    echo "  fix: resolve login redirect issue"
    echo "  refactor(api): simplify error handling"
    echo "  docs: update API documentation"
    echo ""
    echo "See docs/COMMIT_MESSAGE_GUIDE.md for detailed guidelines."
    exit 1
fi

# Additional validation: check description length
description="$(echo "$first_line" | sed -E "s/^($allowed_types)(\(.+\))?: //")"
description_length="${#description}"

if [ "$description_length" -lt 10 ]; then
    echo "Commit message description too short (minimum 10 characters)"
    echo "Current length: $description_length"
    echo "Description: $description"
    exit 1
fi

if [ "$description_length" -gt 100 ]; then
    echo "Warning: Commit message description is quite long ($description_length characters)"
    echo "Consider keeping the subject line under 72 characters for better readability."
    echo ""
fi

# Check for trailing period (should not end with period)
if echo "$first_line" | grep -qE "\.$"; then
    echo "Warning: Commit message should not end with a period"
    echo ""
fi

echo "Commit message format validated successfully"
exit 0
